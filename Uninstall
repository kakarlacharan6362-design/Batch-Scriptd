@echo off
set "processes=CustomSettingCaptionDesigner.exe EspritFileManager.exe ESPRIT.KBMManager.exe ESPRIT.NCEDIT.exe ESPRIT.SettingsManager.exe hh.exe DpTechnology.SecurityManager.exe"

for %%i in (%processes%) do (
    tasklist | find /i "%%i" >nul 2>nul
    if errorlevel 1 (
        echo %%i is not running.
    ) else (
        echo %%i is running. Killing the process...
        taskkill /F /IM "%%i" >nul 2>nul
        echo %%i has been terminated.
    )
)

